# =============================================
# KONFIGURASI DATABASE (MySQL)
# =============================================
MYSQL_ROOT_PASSWORD=rootpassword_ganti_ini
MYSQL_DATABASE=akademik_db
MYSQL_USER=admin
MYSQL_PASSWORD=password_ganti_ini

# =============================================
# KONFIGURASI APLIKASI NODE.JS
# =============================================
APP_PORT=3000
DB_HOST=mysql
DB_PORT=3306
DB_NAME=akademik_db
DB_USER=admin
DB_PASSWORD=password_ganti_ini

# =============================================
# KONFIGURASI MINIO (Object Storage)
# =============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123_ganti_ini
MINIO_BUCKET=students
MINIO_ENDPOINT=minio
MINIO_PORT=9000
# URL publik MinIO untuk akses file dari browser
# Gunakan 'localhost' atau domain custom (misal: localhost setelah setup hosts file Windows)
# Jika menggunakan siam.local, pastikan hosts file sudah dikonfigurasi
MINIO_PUBLIC_HOST=localhost

# =============================================
# KONFIGURASI phpMyAdmin
# =============================================
PMA_HOST=mysql
PMA_PORT=3306
